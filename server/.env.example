DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zipp
SESSION_SECRET=change-me-in-production-min-32-chars
ARGON2_PEPPER=change-me-in-production
ARGON2_MEMORY_MB=128
ARGON2_TIME=3
ARGON2_PARALLELISM=1
ARGON2_HASH_LEN=32
SESSION_LENGTH=30d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KLIPY_API_KEY=
# SMTP for email verification (e.g. Gmail App Password or Postfix relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Zipp <noreply@sinisterswiss.ch>
DATA_DIR=/var/lib/zipp
SERVER_URL=https://ZIPP_SERVER_DOMAIN
FRONTEND_URL=https://ZIPP_SERVER_DOMAIN
ALLOW_SIGNUPS=true
PORT=4200
NODE_ENV=production
LOG_LEVEL=info
