generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  username       String    @unique
  hashedPassword String?
  displayName    String?
  avatarUrl      String?
  publicKey           String?
  encryptedPrivateKey String?
  keySalt             String?
  keyNonce            String?
  isAdmin             Boolean   @default(false)
  emailVerified  Boolean   @default(false)
  verifyToken    String?   @unique
  verifyTokenExp DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  sentMessages    Message[]                 @relation("sender")
  reactions       Reaction[]
  participants    ConversationParticipant[]
  epochsCreated   ConversationEpoch[]       @relation("EpochCreator")
  epochKeys       EpochKey[]                @relation("EpochKeyOwner")
  epochKeysWrapped EpochKey[]               @relation("EpochKeyWrapper")
}

model Account {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model Session {
  id         String   @id
  userId     String?
  data       Json
  ip         String?
  userAgent  String?
  device     String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  epochs       ConversationEpoch[]
}

enum ConversationRole {
  MEMBER
  ADMIN
}

model ConversationParticipant {
  conversationId String
  userId         String
  role           ConversationRole @default(MEMBER)
  joinedAt       DateTime         @default(now())
  leftAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model ConversationEpoch {
  id             String   @id @default(cuid())
  conversationId String
  epochNumber    Int
  createdAt      DateTime @default(now())
  createdById    String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("EpochCreator", fields: [createdById], references: [id])
  keys         EpochKey[]
  messages     Message[]

  @@unique([conversationId, epochNumber])
  @@index([conversationId])
}

model EpochKey {
  id           String @id @default(cuid())
  epochId      String
  userId       String
  encryptedKey String
  keyNonce     String
  wrappedById  String

  epoch     ConversationEpoch @relation(fields: [epochId], references: [id], onDelete: Cascade)
  user      User              @relation("EpochKeyOwner", fields: [userId], references: [id], onDelete: Cascade)
  wrappedBy User              @relation("EpochKeyWrapper", fields: [wrappedById], references: [id])

  @@unique([epochId, userId])
  @@index([epochId])
  @@index([userId])
}

model Message {
  id                  String      @id @default(cuid())
  conversationId      String
  senderId            String
  recipientCiphertext String?
  senderCiphertext    String?
  ciphertext          String?
  nonce               String?
  epochId             String?
  type                MessageType @default(TEXT)
  replyToId           String?
  readAt              DateTime?
  editedAt            DateTime?
  deletedAt           DateTime?
  createdAt           DateTime    @default(now())

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation("sender", fields: [senderId], references: [id])
  epoch        ConversationEpoch? @relation(fields: [epochId], references: [id], onDelete: SetNull)
  replyTo      Message?           @relation("replies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]          @relation("replies")
  reactions    Reaction[]

  @@index([conversationId, createdAt])
  @@index([epochId])
}

enum MessageType {
  TEXT
  GIF
  IMAGE
  VIDEO
  FILE
}

// Tracks uploaded attachment files (referenced by URL in encrypted message payload)
model Attachment {
  id         String   @id @default(cuid())
  uploaderId String
  url        String // /uploads/attachments/<filename>
  thumbUrl   String? // /uploads/thumbs/<filename> — for images & video posters
  mimeType   String
  sizeBytes  Int
  duration   Int? // video duration in seconds
  createdAt  DateTime @default(now())
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}
